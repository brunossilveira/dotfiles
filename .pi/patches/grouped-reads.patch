+import { Container, Spacer, Text } from "@mariozechner/pi-tui";
+import { theme } from "../theme/theme.js";
+/**
+ * ReadToolGroupComponent — groups consecutive Read tool calls into a compact tree view.
+ *
+ * Implements the same interface as ToolExecutionComponent so the pendingTools map
+ * can hold either type transparently.
+ */
+export class ReadToolGroupComponent extends Container {
+    entries = new Map();
+    contentText;
+    expanded = false;
+    showImages;
+    constructor(options = {}) {
+        super();
+        this.showImages = options.showImages ?? true;
+        this.addChild(new Spacer(1));
+        this.contentText = new Text("", 1, 1, (text) => theme.bg("toolPendingBg", text));
+        this.addChild(this.contentText);
+        this.updateDisplay();
+    }
+    hasToolCallId(toolCallId) {
+        return this.entries.has(toolCallId);
+    }
+    updateArgs(args, toolCallId) {
+        const path = args?.path || args?.file_path || "...";
+        const offset = args?.offset;
+        const limit = args?.limit;
+        const existing = this.entries.get(toolCallId);
+        if (existing) {
+            existing.path = path;
+            existing.offset = offset;
+            existing.limit = limit;
+        }
+        else {
+            this.entries.set(toolCallId, {
+                toolCallId,
+                path,
+                offset,
+                limit,
+                status: "pending",
+            });
+        }
+        this.updateDisplay();
+    }
+    markExecutionStarted(toolCallId) {
+        const entry = this.entries.get(toolCallId);
+        if (entry && entry.status === "pending") {
+            entry.status = "pending";
+        }
+        this.updateDisplay();
+    }
+    updateResult(result, isPartial = false, toolCallId) {
+        if (toolCallId) {
+            const entry = this.entries.get(toolCallId);
+            if (entry) {
+                entry.status = result?.isError ? "error" : "success";
+            }
+        }
+        this.updateDisplay();
+    }
+    setExpanded(expanded) {
+        this.expanded = expanded;
+        this.updateDisplay();
+    }
+    setShowImages(show) {
+        this.showImages = show;
+    }
+    setArgsComplete() {
+        this.updateDisplay();
+    }
+    updateDisplay() {
+        const entries = Array.from(this.entries.values());
+        const allDone = entries.length > 0 && entries.every((e) => e.status !== "pending");
+        const hasError = entries.some((e) => e.status === "error");
+        const bgFn = allDone
+            ? hasError
+                ? (text) => theme.bg("toolErrorBg", text)
+                : (text) => theme.bg("toolSuccessBg", text)
+            : (text) => theme.bg("toolPendingBg", text);
+        this.contentText.setCustomBgFn(bgFn);
+        if (entries.length === 0) {
+            this.contentText.setText(theme.fg("toolTitle", theme.bold("read")));
+            return;
+        }
+        if (entries.length === 1) {
+            const e = entries[0];
+            const status = this.formatStatus(e.status);
+            const pathStr = this.formatPath(e);
+            this.contentText.setText(`${status} ${theme.fg("toolTitle", theme.bold("read"))} ${pathStr}`);
+            return;
+        }
+        // Tree view for 2+ entries
+        const header = `${theme.fg("toolTitle", theme.bold("read"))}${theme.fg("dim", ` (${entries.length})`)}`;
+        const lines = [`${this.formatGroupStatus(entries)} ${header}`];
+        for (let i = 0; i < entries.length; i++) {
+            const e = entries[i];
+            const isLast = i === entries.length - 1;
+            const connector = isLast ? "└─" : "├─";
+            const status = this.formatStatus(e.status);
+            const pathStr = this.formatPath(e);
+            lines.push(`   ${theme.fg("dim", connector)} ${status} ${pathStr}`);
+        }
+        this.contentText.setText(lines.join("\n"));
+    }
+    formatStatus(status) {
+        switch (status) {
+            case "success":
+                return theme.fg("success", "✔");
+            case "error":
+                return theme.fg("error", "✘");
+            case "pending":
+                return theme.fg("dim", "⏳");
+        }
+    }
+    formatGroupStatus(entries) {
+        const pending = entries.some((e) => e.status === "pending");
+        const hasError = entries.some((e) => e.status === "error");
+        if (pending) return theme.fg("dim", "⏳");
+        if (hasError) return theme.fg("error", "✘");
+        return theme.fg("success", "✔");
+    }
+    formatPath(entry) {
+        let p = entry.path;
+        const home = process.env.HOME || process.env.USERPROFILE || "";
+        if (home && p.startsWith(home)) {
+            p = "~" + p.slice(home.length);
+        }
+        let text = theme.fg("accent", p);
+        if (entry.offset !== undefined || entry.limit !== undefined) {
+            const start = entry.offset ?? 1;
+            const end = entry.limit !== undefined ? start + entry.limit - 1 : "";
+            text += theme.fg("warning", `:${start}${end ? `-${end}` : ""}`);
+        }
+        return text;
+    }
+    // ToolExecutionComponent interface compatibility
+    render(width) {
+        return super.render(width);
+    }
+    invalidate() {
+        super.invalidate();
+        this.updateDisplay();
+    }
+}
